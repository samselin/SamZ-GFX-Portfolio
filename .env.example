# .env.local
# Copy this file, rename to .env.local, and fill in your Supabase config.
# Get these values from: supabase.com → Project Settings → API

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Cloudinary to bypass Supabase 50MB file size limit
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset_name
